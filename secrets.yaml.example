# Copy this file to secrets.yaml and fill in your own values.
# Do not commit secrets.yaml to GitHub.

wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# Generate this in ESPHome/Home Assistant when adopting the device.
api_key: "YOUR_ESPHOME_API_ENCRYPTION_KEY"

# Choose your own OTA and fallback AP passwords.
ota_password: "YOUR_OTA_PASSWORD"
ap_password: "YOUR_SETUP_AP_PASSWORD"

